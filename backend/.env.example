# Copy this file to .env and fill in your values
# Never commit .env to version control

# PostgreSQL connection details
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=audio_practice

# Port the Express server will listen on
PORT=4000

# Path to the Python executable inside the venv
PYTHON_PATH=../.venv/Scripts/python.exe

# Absolute path to the ML analyze.py script
ML_SCRIPT_PATH=../ML/analyze.py

# Folder where uploaded audio files are temporarily stored
UPLOAD_DIR=./uploads
